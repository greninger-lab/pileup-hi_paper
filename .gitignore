*.bam
*.bai
*.cram
*.crai

# Logs
*.log
.command.log
.nextflow.log*
compare_output_*.log

# Temp / cache
__pycache__/
.snakemake/
.RData
.Rhistory
.DS_Store
zenodo_upload/

