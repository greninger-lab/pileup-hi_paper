outputs/
output/
results/
reports/
hashes/
figures/
bench_files/
cuts/
old/

# Local binaries (built by cargo or symlinked)
pileuphi
samtools

# Old CSV/Excel results (published results are tracked)
*.numbers
*.xlsx
